# Database
DATABASE_URL="postgresql://jobradar:jobradar@localhost:5432/jobradar?schema=public"

# Owner identity (used by scripts/backfill-user0 to seed the first User,
# and auto-whitelisted for auth regardless of BETA_EMAILS)
OWNER_EMAIL= # fallback: owner@local
OWNER_USER_ID= # cuid of the owner User row (User #0 after backfill)

# Closed-beta allow-list for auth (comma-separated emails, case-insensitive).
# Owner from OWNER_EMAIL is whitelisted regardless. Empty → only owner.
BETA_EMAILS=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram Bot (grammY)
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_WHITELIST_CHAT_ID=your_chat_id

# LLM (llama-server on the rig, or a remote vLLM endpoint)
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL= # optional, will read from /v1/models if empty
LLM_MODEL_SCORE= # optional, override for scoring task; falls back to LLM_MODEL
LLM_MODEL_PARSE= # optional, override for cv-parse task; falls back to LLM_MODEL
LLM_MODEL_EXTRACT= # optional, override for extract task; falls back to LLM_MODEL
LLM_BASE_URL_SCORE= # optional, override base URL for scoring task; falls back to LLM_BASE_URL
LLM_BASE_URL_PARSE= # optional, override base URL for cv-parse task; falls back to LLM_BASE_URL
LLM_BASE_URL_EXTRACT= # optional, override base URL for extract task; falls back to LLM_BASE_URL
LLM_API_KEY= # optional, sent as Bearer token (required for remote endpoints)
LLM_THINKING=true # reasoning mode for scoring; set false for bulk extraction

# GramJS user session for reading channels (Phase 2+)
# Generate via login script or store string
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION= # string from GramJS login

# App
PORT=3000
SCORING_THRESHOLD=65
SCORING_CONCURRENCY=1 # keep 1 for llama-server; 6-8 for vLLM
